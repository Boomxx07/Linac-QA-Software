<UserControl x:Class="Linac_QA_Software.Views.TPR2010View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Linac_QA_Software.ViewModels"
             xmlns:helpers="clr-namespace:Linac_QA_Software.Helpers"
             helpers:ScrollViewerExtension.BubbleMouseWheel="True"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1200"
             Background="White"
             d:DataContext="{d:DesignInstance Type=viewmodels:TPR2010ViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#E0FFFF"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="helpers:NumericInputBehavior.IsNumericOnly" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CalculatedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#E6E6FA"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="TPR(10)20 Measurements (All Energies)" 
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="Measurement Instruction: SSD values are 80cm and 90cm; Depths are 20cm and 10cm respectively" 
                       Margin="0,0,0,10" TextWrapping="Wrap"/>

            <!-- Consolidated table for all energies with proper row spanning -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                </Grid.RowDefinitions>

                <!-- Header row -->
                <Border Grid.Row="0" Grid.ColumnSpan="10" BorderBrush="Black" BorderThickness="1" Background="#F0F0F0"/>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Energy" Style="{StaticResource HeaderTextBlockStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="SSD (cm)" Style="{StaticResource HeaderTextBlockStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Depth (cm)" Style="{StaticResource HeaderTextBlockStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Reading 1" Style="{StaticResource HeaderTextBlockStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="Reading 2" Style="{StaticResource HeaderTextBlockStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="5" Text="Reading 3" Style="{StaticResource HeaderTextBlockStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="6" Text="Average (nC)" Style="{StaticResource HeaderTextBlockStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="7" Text="TPR(10)20" Style="{StaticResource HeaderTextBlockStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="8" Text="% Diff from Baseline" Style="{StaticResource HeaderTextBlockStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="9" Text="Result" Style="{StaticResource HeaderTextBlockStyle}"/>

                <!-- 6MV row 1 (SSD=80, Depth=20) -->
                <Border Grid.Row="1" Grid.ColumnSpan="10" BorderBrush="Black" BorderThickness="1,0,1,0"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Text="6MV" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="80" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding EnergyRows[0].Row80_20.Reading1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding EnergyRows[0].Row80_20.Reading2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding EnergyRows[0].Row80_20.Reading3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="1" Grid.Column="6" Text="{Binding EnergyRows[0].Row80_20.Average, StringFormat={}{0:F3}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}"/>
                <TextBox Grid.Row="1" Grid.RowSpan="2" Grid.Column="7" Text="{Binding EnergyRows[0].TPR2010Value, StringFormat={}{0:F4}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}" VerticalAlignment="Center" Height="30" Margin="1,0,1,0"/>
                <TextBox Grid.Row="1" Grid.RowSpan="2" Grid.Column="8" Text="{Binding EnergyRows[0].PercentDiff, StringFormat={}{0:F2}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}" VerticalAlignment="Center" Height="30"/>
                <TextBox Grid.Row="1" Grid.RowSpan="2" Grid.Column="9" Text="{Binding EnergyRows[0].StatusText, Mode=OneWay}" VerticalAlignment="Center" Height="30">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource CalculatedTextBoxStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EnergyRows[0].StatusText}" Value="FAIL">
                                    <Setter Property="Background" Value="Red"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EnergyRows[0].StatusText}" Value="CAUTIONARY">
                                    <Setter Property="Background" Value="Orange"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EnergyRows[0].StatusText}" Value="OK">
                                    <Setter Property="Background" Value="LawnGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- 6MV row 2 (SSD=90, Depth=10) -->
                <Border Grid.Row="2" Grid.ColumnSpan="10" BorderBrush="Black" BorderThickness="1,0,1,1"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="90" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding EnergyRows[0].Row90_10.Reading1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding EnergyRows[0].Row90_10.Reading2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding EnergyRows[0].Row90_10.Reading3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="2" Grid.Column="6" Text="{Binding EnergyRows[0].Row90_10.Average, StringFormat={}{0:F3}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}"/>

                <!-- 10MV row 1 (SSD=80, Depth=20) -->
                <Border Grid.Row="3" Grid.ColumnSpan="10" BorderBrush="Black" BorderThickness="1,0,1,0"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Grid.RowSpan="2" Text="10MV" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="80" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="3" Grid.Column="2" Text="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding EnergyRows[1].Row80_20.Reading1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="3" Grid.Column="4" Text="{Binding EnergyRows[1].Row80_20.Reading2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="3" Grid.Column="5" Text="{Binding EnergyRows[1].Row80_20.Reading3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="3" Grid.Column="6" Text="{Binding EnergyRows[1].Row80_20.Average, StringFormat={}{0:F3}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}"/>
                <TextBox Grid.Row="3" Grid.RowSpan="2" Grid.Column="7" Text="{Binding EnergyRows[1].TPR2010Value, StringFormat={}{0:F4}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}" VerticalAlignment="Center" Height="30"/>
                <TextBox Grid.Row="3" Grid.RowSpan="2" Grid.Column="8" Text="{Binding EnergyRows[1].PercentDiff, StringFormat={}{0:F2}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}" VerticalAlignment="Center" Height="30"/>
                <TextBox Grid.Row="3" Grid.RowSpan="2" Grid.Column="9" Text="{Binding EnergyRows[1].StatusText, Mode=OneWay}" VerticalAlignment="Center" Height="30">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource CalculatedTextBoxStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EnergyRows[1].StatusText}" Value="FAIL">
                                    <Setter Property="Background" Value="Red"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EnergyRows[1].StatusText}" Value="CAUTIONARY">
                                    <Setter Property="Background" Value="Orange"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EnergyRows[1].StatusText}" Value="OK">
                                    <Setter Property="Background" Value="LawnGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- 10MV row 2 (SSD=90, Depth=10) -->
                <Border Grid.Row="4" Grid.ColumnSpan="10" BorderBrush="Black" BorderThickness="1,0,1,1"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="90" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="4" Grid.Column="2" Text="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding EnergyRows[1].Row90_10.Reading1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="4" Grid.Column="4" Text="{Binding EnergyRows[1].Row90_10.Reading2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="4" Grid.Column="5" Text="{Binding EnergyRows[1].Row90_10.Reading3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="4" Grid.Column="6" Text="{Binding EnergyRows[1].Row90_10.Average, StringFormat={}{0:F3}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}"/>

                <!-- 6FFF row 1 (SSD=80, Depth=20) -->
                <Border Grid.Row="5" Grid.ColumnSpan="10" BorderBrush="Black" BorderThickness="1,0,1,0"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="6FFF" Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Grid.Row="5" Grid.Column="1" Text="80" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="5" Grid.Column="2" Text="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding EnergyRows[2].Row80_20.Reading1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="5" Grid.Column="4" Text="{Binding EnergyRows[2].Row80_20.Reading2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="5" Grid.Column="5" Text="{Binding EnergyRows[2].Row80_20.Reading3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="5" Grid.Column="6" Text="{Binding EnergyRows[2].Row80_20.Average, StringFormat={}{0:F3}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}"/>
                <TextBox Grid.Row="5" Grid.RowSpan="2" Grid.Column="7" Text="{Binding EnergyRows[2].TPR2010Value, StringFormat={}{0:F4}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}" VerticalAlignment="Center" Height="30"/>
                <TextBox Grid.Row="5" Grid.RowSpan="2" Grid.Column="8" Text="{Binding EnergyRows[2].PercentDiff, StringFormat={}{0:F2}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}" VerticalAlignment="Center" Height="30"/>
                <TextBox Grid.Row="5" Grid.RowSpan="2" Grid.Column="9" Text="{Binding EnergyRows[2].StatusText, Mode=OneWay}" VerticalAlignment="Center" Height="30">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource CalculatedTextBoxStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EnergyRows[2].StatusText}" Value="FAIL">
                                    <Setter Property="Background" Value="Red"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EnergyRows[2].StatusText}" Value="CAUTIONARY">
                                    <Setter Property="Background" Value="Orange"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EnergyRows[2].StatusText}" Value="OK">
                                    <Setter Property="Background" Value="LawnGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- 6FFF row 2 (SSD=90, Depth=10) -->
                <Border Grid.Row="6" Grid.ColumnSpan="10" BorderBrush="Black" BorderThickness="1,0,1,1"/>
                <TextBlock Grid.Row="6" Grid.Column="1" Text="90" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="6" Grid.Column="2" Text="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBox Grid.Row="6" Grid.Column="3" Text="{Binding EnergyRows[2].Row90_10.Reading1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="6" Grid.Column="4" Text="{Binding EnergyRows[2].Row90_10.Reading2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="6" Grid.Column="5" Text="{Binding EnergyRows[2].Row90_10.Reading3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                <TextBox Grid.Row="6" Grid.Column="6" Text="{Binding EnergyRows[2].Row90_10.Average, StringFormat={}{0:F3}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
