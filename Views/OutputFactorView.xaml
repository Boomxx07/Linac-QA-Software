<UserControl x:Class="Linac_QA_Software.Views.OutputFactorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Linac_QA_Software.ViewModels"
             xmlns:helpers="clr-namespace:Linac_QA_Software.Helpers"
             xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf"
             helpers:ScrollViewerExtension.BubbleMouseWheel="True"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="White"
             d:DataContext="{d:DesignInstance Type=viewmodels:OutputFactorViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#E0FFFF"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="helpers:NumericInputBehavior.IsNumericOnly" Value="True"/>
            <Style.Triggers>
                <!-- Show red border when validation errors are present -->
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CalculatedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#E6E6FA"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding EnergyConfigs}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <GroupBox Header="{Binding EnergyName}" Margin="0,0,0,20" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.ColumnSpan="3" Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="{Binding MeasurementInstruction}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,10,0">

                                <TextBlock Text="Output Factor Measurements" Style="{StaticResource HeaderTextBlockStyle}" HorizontalAlignment="Left" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Background="#F0F0F0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.ColumnSpan="6" BorderBrush="Black" BorderThickness="1"/>

                                        <TextBlock Grid.Column="0" Text="Field Size (X×Y)" Style="{StaticResource HeaderTextBlockStyle}"/>
                                        <TextBlock Grid.Column="1" Text="Readings (nC)" Style="{StaticResource HeaderTextBlockStyle}"/>
                                        <TextBlock Grid.Column="2" Text="Average (nC)" Style="{StaticResource HeaderTextBlockStyle}"/>
                                        <TextBlock Grid.Column="3" Text="Output Factor" Style="{StaticResource HeaderTextBlockStyle}"/>
                                        <TextBlock Grid.Column="4" Text="% Diff from Baseline" Style="{StaticResource HeaderTextBlockStyle}"/>
                                        <TextBlock Grid.Column="5" Text="Result" Style="{StaticResource HeaderTextBlockStyle}"/>
                                    </Grid>

                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="25">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="90"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.ColumnSpan="8" BorderBrush="Black" BorderThickness="1,0,1,1"/>

                                                    <TextBlock Grid.Column="0" Text="{Binding FieldLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                                    <TextBox Grid.Column="1" Text="{Binding Reading1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                                                    <TextBox Grid.Column="2" Text="{Binding Reading2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>
                                                    <TextBox Grid.Column="3" Text="{Binding Reading3, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}"/>

                                                    <TextBox Grid.Column="4" Text="{Binding Average, StringFormat={}{0:F3}, Mode=OneWay}" Style="{StaticResource CalculatedTextBoxStyle}"/>

                                                    <TextBox Grid.Column="5">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox" BasedOn="{StaticResource CalculatedTextBoxStyle}">
                                                                <Setter Property="Text" Value="{Binding OutputFactor, StringFormat={}{0:F4}, Mode=OneWay}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsReference}" Value="True">
                                                                        <Setter Property="Text" Value="N/A"/>
                                                                        <Setter Property="Background" Value="White"/>
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>

                                                    <TextBox Grid.Column="6">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox" BasedOn="{StaticResource CalculatedTextBoxStyle}">
                                                                <Setter Property="Text" Value="{Binding PercentDiff, StringFormat={}{0:F2}, Mode=OneWay}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsReference}" Value="True">
                                                                        <Setter Property="Text" Value="N/A"/>
                                                                        <Setter Property="Background" Value="White"/>
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>

                                                    <TextBox Grid.Column="7">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox" BasedOn="{StaticResource CalculatedTextBoxStyle}">
                                                                <Setter Property="Text" Value="{Binding StatusText, Mode=OneWay}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsReference}" Value="True">
                                                                        <Setter Property="Text" Value="N/A"/>
                                                                        <Setter Property="Background" Value="White"/>
                                                                        <Setter Property="BorderThickness" Value="0"/>
                                                                    </DataTrigger>

                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsReference}" Value="False"/>
                                                                            <Condition Binding="{Binding StatusText}" Value="FAIL"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Background" Value="Red"/>
                                                                    </MultiDataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsReference}" Value="False"/>
                                                                            <Condition Binding="{Binding StatusText}" Value="CAUTIONARY"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Background" Value="Orange"/>
                                                                    </MultiDataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsReference}" Value="False"/>
                                                                            <Condition Binding="{Binding StatusText}" Value="OK"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Background" Value="LawnGreen"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </StackPanel>

                            <!-- Charts Section -->
                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="10,0,0,0">
                                <oxy:PlotView Model="{Binding SymmetricFieldsPlotModel}" Height="350" Margin="0,0,0,10" helpers:ResponsiveVisibility.MinWidth="1400"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Grid.Row="1" Margin="10,0,0,0">
                                <oxy:PlotView Model="{Binding AsymmetricFieldsPlotModel}" Height="350" Margin="0,0,0,10" helpers:ResponsiveVisibility.MinWidth="1400"/>
                            </StackPanel>

                        </Grid>
                    </GroupBox>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
