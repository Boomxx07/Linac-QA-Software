<Window x:Class="Linac_QA_Software.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Linac_QA_Software.Views"
        xmlns:helpers="clr-namespace:Linac_QA_Software.Helpers"
        xmlns:viewmodels="clr-namespace:Linac_QA_Software.ViewModels"
        mc:Ignorable="d"
        Title="SCGH Linac QA" Height="900" Width="1000"
        MinWidth="810"
        MinHeight="300"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel, IsDesignTimeCreatable=True}">

    <DockPanel Margin="15">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="Save Draft" Width="120" Height="30" Margin="5" Command="{Binding SaveCommand}"/>
            <Button Content="Final Submit" Width="120" Height="30" Margin="5" Command="{Binding SubmitCommand}" Background="AliceBlue"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical" Margin="0,0,15,0">

                <TextBlock Text="Annual Photons Linac QA" FontSize="26" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>

                <Border Background="#F9F9F9" CornerRadius="5" Padding="15" Margin="0,0,0,20" BorderBrush="#DDD" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="Linac Machine" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding LinacOptions}"
                                      SelectedItem="{Binding Linac}" 
                                      Height="25"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock Text="Test Date" FontWeight="Bold" Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding Date}" Height="25"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Attending Physicists" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ListBox SelectionMode="Multiple"
                                     ItemsSource="{Binding PhysicistList}"
                                     helpers:ListBoxHelper.SelectedItems="{Binding SelectedPhysicists}"
                                     Height="80" 
                                     BorderBrush="#CCC"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Separator Margin="0,10"/>
                <TextBlock Text="Linearity" FontSize="20" FontWeight="Bold" Margin="0,10"/>
                <views:LinearityView DataContext="{Binding LinearityVM}" />

                <Separator Margin="0,10"/>
                <TextBlock Text="Output Factor" FontSize="20" FontWeight="Bold" Margin="0,10"/>
                <views:OutputFactorView DataContext="{Binding OutputFactorVM}" />

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>